#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

export UV_CACHE_DIR="${SIGNAL_LIGHT_UV_CACHE_DIR:-/private/tmp/signal-light-uv-cache}"

if [[ "${SIGNAL_LIGHT_USE_UV:-0}" == "1" ]] && command -v uv >/dev/null 2>&1; then
  exec uv run python -m signal_light codex-hook "$@"
fi

exec python3 -m signal_light codex-hook "$@"
